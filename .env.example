APP_ENV=development
APP_NAME=telegram-ai-brooch
GIT_COMMIT=unknown
BUILD_TIME=unknown

BOT_TOKEN=
ASSISTANT_SERVICE_TOKEN=
JARHERT_BACKEND_URL=http://backend:8000
PERSONAL_OS_DB=~/.hermes/data/personal-os.sqlite3
PERSONAL_EXPORT_DIR=./data/personal_exports
ADMIN_TG_USER_IDS=
HERMES_OWNER_TELEGRAM_CHAT_ID=
MONITOR_DAILY_LLM_BUDGET=10
SUBSCRIPTION_SYNC_COMMAND=
ALLOWED_TG_USER_IDS=
# SQLite is for local development only. Production uses PostgreSQL.
DATABASE_URL=sqlite:///./data/ai_brooch.sqlite3
# POSTGRES_DB=jarhert
# POSTGRES_USER=jarhert
# POSTGRES_PASSWORD=
# DATABASE_URL=postgresql+psycopg://jarhert:<password>@postgres:5432/jarhert

AI_ENABLED=true
AI_COST_MODE=free_only
AI_ALLOW_PAID_FALLBACK=false
AI_REPLY_TO_PLAIN_TEXT=true
AI_DAILY_USER_LIMIT=0
AI_DAILY_GLOBAL_LIMIT=0
AI_MAX_INPUT_CHARS=4000
AI_MAX_OUTPUT_CHARS=2500
AI_STYLE_ENABLED=true
# Optional override. Empty uses assistant/prompts/jarhert_communication_style.md.
AI_STYLE_PROMPT_PATH=
AI_REQUEST_TIMEOUT_SECONDS=25
# Provider-router policy. Budget is an estimated per-request USD-micro ledger;
# keep it at 0 to guarantee that cheap/paid providers are never reserved.
AI_PROVIDER_DEADLINE_SECONDS=15
AI_PROVIDER_MAX_ATTEMPTS=2
AI_PROVIDER_COOLDOWN_SECONDS=120
AI_PROVIDER_DAILY_BUDGET_MICRO_USD=0
AI_PROVIDER_MIN_QUALITY_SCORE=60

HERMES_MODE=fake
# Use provider_router to route across OpenRouter/OpenAI/Hermes CLI/Groq/HF with circuit breaker.
# HERMES_MODE=provider_router
HERMES_API_URL=http://127.0.0.1:8765
HERMES_API_PATH=/api/chat
HERMES_API_TOKEN=
HERMES_CLI_COMMAND=hermes --oneshot {prompt}
HERMES_CLI_COMMAND_TEMPLATE=hermes --provider openrouter --model {model} --oneshot {prompt}
HERMES_CLI_ENABLED=true
HERMES_CLI_MODELS=openrouter/free
HERMES_PAID_FALLBACK_MODELS=
HERMES_TIMEOUT_SECONDS=25
HERMES_CLI_ESTIMATED_COST_MICRO_USD=1000
HERMES_SESSION_NAME=telegram-ai-brooch
HERMES_PROVIDER_ORDER=gemini,openrouter,groq,huggingface
HERMES_TOOLS_ENABLED=false

OPENAI_MODEL=gpt-5-nano
# Optional OpenAI fine-tuned model for scripts/eval_model_holdout.py only.
FINE_TUNED_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_ESTIMATED_COST_MICRO_USD=1000
PAID_ESTIMATED_COST_MICRO_USD=10000
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENROUTER_API_KEY=
OPENROUTER_ENABLED=true
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=12
OPENROUTER_MAX_OUTPUT_TOKENS=500
OPENROUTER_ESTIMATED_COST_MICRO_USD=1000
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=10
GROQ_MAX_OUTPUT_TOKENS=500
HF_API_KEY=
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_TIMEOUT_SECONDS=15
HF_MAX_OUTPUT_TOKENS=500
VOICE_MAX_BYTES=10485760
TELEGRAM_BLOCKING_MAX_CONCURRENCY=4
TELEGRAM_BLOCKING_TIMEOUT_SECONDS=60
TELEGRAM_FAST_ACK_SECONDS=0.6
TRAINING_FEEDBACK_BUTTONS_ENABLED=false
GOOGLE_DOCS_WEBHOOK_URL=
GOOGLE_DOCS_WEBHOOK_TOKEN=
GOOGLE_DOCS_WEBHOOK_TIMEOUT_SECONDS=5
ENABLE_GOOGLE_SHEETS_SYNC=false
GOOGLE_SPREADSHEET_ID=
GOOGLE_ASSISTANT_SHEET_NAME=AI Brooch
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_X509_CERT_URL=
TASK_COMMAND_CENTER_ENABLED=true
TASK_COMMAND_CENTER_DIR=/opt/task-command-center
TASK_COMMAND_CENTER_PYTHON=.venv/bin/python
TASK_COMMAND_CENTER_TIMEOUT_SECONDS=45
TASK_COMMAND_CENTER_HEALTH_CACHE_SECONDS=30
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional MTProto collector for selected Telegram chats/channels.
# Get API ID/hash at https://my.telegram.org/apps.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_COLLECTOR_SESSION=./data/telegram_collector.session
# Separate, already authorized MTProto user session for strict live system E2E.
LIVE_E2E_TELETHON_SESSION=./data/live_e2e_user.session
# Comma-separated refs or JSON list: @channel,-1001234567890
TELEGRAM_COLLECTOR_CHATS=
TELEGRAM_COLLECTOR_CHATS_FILE=
TELEGRAM_COLLECTOR_HEALTH_HOST=127.0.0.1
TELEGRAM_COLLECTOR_HEALTH_PORT=8091
TELEGRAM_COLLECTOR_HEARTBEAT_SECONDS=60

# Trendwatch worker reads collected messages and delivers summary to this Telegram user.
# If empty, first ADMIN_TG_USER_IDS value is used.
TELEGRAM_TREND_TG_USER_ID=
TELEGRAM_TREND_INTERVAL_SECONDS=3600
TELEGRAM_TREND_LOOKBACK_HOURS=6
TELEGRAM_TREND_BATCH_LIMIT=300
