APP_ENV=development
APP_NAME=telegram-ai-brooch
GIT_COMMIT=unknown
BUILD_TIME=unknown

BOT_TOKEN=
ASSISTANT_SERVICE_TOKEN=
ADMIN_TG_USER_IDS=
ALLOWED_TG_USER_IDS=
DATABASE_URL=sqlite:///./data/ai_brooch.sqlite3

AI_ENABLED=true
AI_COST_MODE=free_only
AI_ALLOW_PAID_FALLBACK=false
AI_REPLY_TO_PLAIN_TEXT=true
AI_DAILY_USER_LIMIT=20
AI_DAILY_GLOBAL_LIMIT=200
AI_MAX_INPUT_CHARS=4000
AI_MAX_OUTPUT_CHARS=2500
AI_REQUEST_TIMEOUT_SECONDS=25

HERMES_MODE=fake
# Use provider_router to route across OpenRouter/OpenAI/Hermes CLI/Groq/HF with circuit breaker.
# HERMES_MODE=provider_router
HERMES_API_URL=http://127.0.0.1:8765
HERMES_API_PATH=/api/chat
HERMES_API_TOKEN=
HERMES_CLI_COMMAND=hermes --oneshot {prompt}
HERMES_CLI_COMMAND_TEMPLATE=hermes --provider openrouter --model {model} --oneshot {prompt}
HERMES_CLI_MODELS=openrouter/free
HERMES_PAID_FALLBACK_MODELS=
HERMES_TIMEOUT_SECONDS=25
HERMES_SESSION_NAME=telegram-ai-brooch
HERMES_PROVIDER_ORDER=gemini,openrouter,groq,huggingface
HERMES_TOOLS_ENABLED=false

OPENAI_MODEL=gpt-5-nano
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=12
OPENROUTER_MAX_OUTPUT_TOKENS=500
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=10
GROQ_MAX_OUTPUT_TOKENS=500
HF_API_KEY=
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_TIMEOUT_SECONDS=15
HF_MAX_OUTPUT_TOKENS=500
VOICE_MAX_BYTES=10485760
GOOGLE_DOCS_WEBHOOK_URL=
GOOGLE_DOCS_WEBHOOK_TOKEN=
GOOGLE_DOCS_WEBHOOK_TIMEOUT_SECONDS=5
ENABLE_GOOGLE_SHEETS_SYNC=false
GOOGLE_SPREADSHEET_ID=
GOOGLE_ASSISTANT_SHEET_NAME=AI Brooch
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_CLIENT_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_X509_CERT_URL=
TASK_COMMAND_CENTER_ENABLED=true
TASK_COMMAND_CENTER_DIR=/Users/mihailkulibaba/Documents/New project/task-command-center
TASK_COMMAND_CENTER_PYTHON=.venv/bin/python
TASK_COMMAND_CENTER_TIMEOUT_SECONDS=45
OPENAI_API_KEY=
GEMINI_API_KEY=
