# Copy this file to the private Hermes profile environment:
# ~/.hermes/profiles/jarhert/.env
# Never commit the resulting .env file.

# Hermes gateway: this is the only Telegram runtime for JarHert.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
HERMES_OWNER_TELEGRAM_CHAT_ID=
HERMES_HOME=~/.hermes/profiles/jarhert
HERMES_TIMEZONE=Europe/Moscow

# One Personal OS SQLite database for notes, projects, reminders, contacts,
# monitors and coding-job metadata.
PERSONAL_OS_DB=~/.hermes/profiles/jarhert/data/personal-os.sqlite3

# Trello and Google Calendar live in the external Task Command Center. The
# path is supplied only by the environment; no macOS path is embedded in code.
TASK_COMMAND_CENTER_DIR=/opt/task-command-center
TASK_COMMAND_CENTER_PYTHON=.venv/bin/python
TASK_COMMAND_CENTER_TIMEOUT_SECONDS=45
TASK_COMMAND_CENTER_HEALTH_CACHE_SECONDS=30

# Optional GitHub research. The official MCP remains read-only and disabled
# until its binary and a fine-grained read-only token are installed.
GITHUB_MCP_ENABLED=false
GITHUB_PERSONAL_ACCESS_TOKEN=
HERMES_RESEARCH_ALLOWED_HOSTS=github.com,api.github.com

# Telegram text-only export from chats accessible to the owner's MTProto
# account. Generated documents are deleted after the retention period.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=~/.hermes/profiles/jarhert/data/telegram-user.session
TELEGRAM_EXPORT_DIR=~/.hermes/profiles/jarhert/exports/telegram
TELEGRAM_EXPORT_RETENTION_HOURS=48

# Native Hermes helpers.
HERMES_NATIVE_SEND_COMMAND=
# Keep all features available by default. For a focused MCP profile, use a
# comma-separated set such as personal,planning or research,code. Restart
# Hermes after changing this value.
HERMES_TOOL_BUNDLES=all
MONITOR_DAILY_LLM_BUDGET=10
SUBSCRIPTION_SYNC_COMMAND=
HERMES_CODING_QUEUE_SSH=
# The Mac queue runner uses the authenticated Codex CLI by default. Leave the
# binary empty to prefer ~/.local/bin/codex, or explicitly choose the legacy
# isolated Hermes Docker profile with HERMES_CODING_EXECUTOR=hermes.
HERMES_CODING_EXECUTOR=codex
HERMES_CODEX_BIN=

# Mini App dashboard. Keep it behind HTTPS and a Telegram allowlist.
JARHERT_DASHBOARD_SESSION_SECRET=
JARHERT_DASHBOARD_ALLOWED_TG_USER_IDS=
JARHERT_DASHBOARD_HOST=127.0.0.1
JARHERT_DASHBOARD_PORT=8788
JARHERT_DASHBOARD_SECURE_COOKIE=true

# Optional model providers configured by Hermes itself. Do not put provider
# routing, old backend URLs or service tokens here.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
