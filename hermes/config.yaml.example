model:
  provider: gemini
  default: gemini-2.5-flash-lite

fallback_providers:
  - provider: openrouter
    model: google/gemini-2.0-flash-exp:free
  - provider: groq
    model: llama-3.1-8b-instant
  - provider: huggingface
    model: ""

provider_routing:
  sort: "price"
  require_parameters: true
  data_collection: "deny"

tools:
  enabled: false

