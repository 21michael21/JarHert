[Unit]
Description=JarHert encrypted profile backup and restore proof
ConditionPathExists=%h/.config/jarhert/backup.env

[Service]
Type=oneshot
WorkingDirectory=%h/.hermes/profiles/jarhert
EnvironmentFile=%h/.config/jarhert/backup.env
ExecStart=/bin/bash %h/.hermes/profiles/jarhert/scripts/backup_and_verify.sh
